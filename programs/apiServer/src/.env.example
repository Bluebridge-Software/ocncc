# =============================================================================
# OCNCC Billing Engine Client — Environment Configuration
# © COPYRIGHT: Blue Bridge Software Ltd - 2026
# Author: Tony Craven
#
# Copy this file to .env and fill in values for your environment.
# All settings have sensible defaults — only override what you need.
# =============================================================================


# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------

# Port the API server listens on
BE_PORT=3010

# Host/interface to bind to (0.0.0.0 = all interfaces)
BE_HOST=0.0.0.0

# Full public base URL used in Swagger UI and log output
# Defaults to http://localhost:<BE_PORT> if not set
BE_SERVER_URL=http://localhost:3010

# Description shown in Swagger UI header
BE_SERVER_DESCRIPTION=Local development


# -----------------------------------------------------------------------------
# CLIENT IDENTITY
# -----------------------------------------------------------------------------

# Name sent to billing engines to identify this client
BE_CLIENT_NAME=bbs-be-client


# -----------------------------------------------------------------------------
# BILLING ENGINE CONNECTIONS
# -----------------------------------------------------------------------------

# Whether to load billing engine config from the database (true) or from
# BE_ENGINES below (false)
USE_DATABASE_FOR_BILLING_ENGINES=true

# Static billing engine list — used when USE_DATABASE_FOR_BILLING_ENGINES=false
# Format: "id:primaryIp:primaryPort" or "id:primaryIp:primaryPort:secondaryIp:secondaryPort"
# Multiple engines separated by commas
# Example: BE_ENGINES=1:10.0.0.1:1500:10.0.0.2:1500,2:10.0.0.3:1500
BE_ENGINES=

# How often to re-check engine readiness when using static config (minutes)
# Used to detect engines coming back online after a failure
ENGINE_READINESS_CHECK_MINUTES=1

# How often to re-read engine config from the database and reconcile (minutes)
# Only applies when USE_DATABASE_FOR_BILLING_ENGINES=true
ENGINE_CONFIG_REFRESH_MINUTES=5


# -----------------------------------------------------------------------------
# BILLING ENGINE PROTOCOL TUNING
# -----------------------------------------------------------------------------

# How long to wait for a response from a billing engine (milliseconds)
BE_MESSAGE_TIMEOUT_MS=2000

# How often to send a heartbeat to billing engines (milliseconds)
BE_HEARTBEAT_INTERVAL_MS=3000

# How long to wait before retrying a failed connection (milliseconds)
BE_CONNECTION_RETRY_MS=5000

# How long to wait before failing back to the primary engine after a failover
# Set to -1 to disable automatic failback
BE_PRIMARY_FAILBACK_MS=-1


# -----------------------------------------------------------------------------
# DATABASE (Oracle)
# -----------------------------------------------------------------------------

# Set to false to disable all Oracle connection attempts entirely.
# /db/* routes will return 503 and no DB Swagger endpoints will be activated.
DATABASE_ENABLED=true

# Oracle credentials
ORACLE_USER=your_db_user
ORACLE_PASSWORD=your_db_password

# Oracle connection string.
# Can be a full TNS descriptor (wrap in double quotes for multi-line) or a TNS alias.
#
# Single-host example (inline):
# ORACLE_SMF_SERVICE=(DESCRIPTION=(CONNECT_TIMEOUT=5)(TRANSPORT_CONNECT_TIMEOUT=3)(RETRY_COUNT=3)(ADDRESS_LIST=(ADDRESS=(PROTOCOL=tcp)(HOST=usms)(PORT=1521)))(CONNECT_DATA=(SERVICE_NAME=SMF.usms.SMF)))
#
# Dual-host with failover (multi-line, requires double quotes):
ORACLE_SMF_SERVICE="(DESCRIPTION_LIST=
  (FAILOVER=on)
  (LOAD_BALANCE=off)
  (DESCRIPTION=
    (CONNECT_TIMEOUT=5)(TRANSPORT_CONNECT_TIMEOUT=3)(RETRY_COUNT=3)
    (ADDRESS_LIST=(ADDRESS=(PROTOCOL=tcp)(HOST=primary-db-host)(PORT=1521)))
    (CONNECT_DATA=(SERVICE_NAME=your_service_name))
  )
  (DESCRIPTION=
    (CONNECT_TIMEOUT=5)(TRANSPORT_CONNECT_TIMEOUT=3)(RETRY_COUNT=3)
    (ADDRESS_LIST=(ADDRESS=(PROTOCOL=tcp)(HOST=standby-db-host)(PORT=1521)))
    (CONNECT_DATA=(SERVICE_NAME=your_service_name))
  )
)"

# TNS alias alternative — set TNS_ADMIN to the directory containing tnsnames.ora
# ORACLE_SMF_SERVICE=SMF
# TNS_ADMIN=/opt/oracle/network/admin

# How often to retry a failed DB connection (minutes)
DB_RETRY_INTERVAL_MINUTES=1

# How often to refresh profile tag metadata from DB (minutes)
PROFILE_TAG_REFRESH_MINUTES=60


# -----------------------------------------------------------------------------
# REDIS CACHE
# -----------------------------------------------------------------------------

# Enable Redis for caching DB query results and API statistics
BE_REDIS_ENABLED=true

# Connection URL — used as fallback if individual host/port fields are not set
# Format: redis://[[username]:[password]@]host:port
BE_REDIS_URL=redis://localhost:6379

# Individual connection parameters — take precedence over BE_REDIS_URL when set
BE_REDIS_HOST=swisspi
BE_REDIS_PORT=6379
BE_REDIS_USER=intellicharter
BE_REDIS_PASSWORD=w1mbold345


# -----------------------------------------------------------------------------
# JWT AUTHENTICATION
# -----------------------------------------------------------------------------

# Enable JWT bearer token authentication on all /api and /db routes
BE_JWT_ENABLED=true

# Secret key used to sign and verify tokens — CHANGE THIS IN PRODUCTION
# Minimum recommended length: 32 characters
BE_JWT_SECRET=YOUR_SUPER_SECRET_KEY_CHANGE_IN_PRODUCTION


# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------

# Maximum API requests per second per IP address
BE_RATE_LIMIT_PER_SECOND=100


# -----------------------------------------------------------------------------
# STATISTICS
# -----------------------------------------------------------------------------

# Width of each statistics time bucket (minutes)
BE_STATS_PERIOD_MINUTES=5

# How long to retain statistics history (days)
BE_STATS_RETENTION_DAYS=3


# -----------------------------------------------------------------------------
# ALERTING — SYSLOG
# -----------------------------------------------------------------------------

BE_SYSLOG_ENABLED=false
BE_SYSLOG_HOST=localhost
BE_SYSLOG_PORT=514


# -----------------------------------------------------------------------------
# ALERTING — SNMP TRAPS
# -----------------------------------------------------------------------------

BE_SNMP_ENABLED=false
BE_SNMP_HOST=localhost
BE_SNMP_PORT=162
BE_SNMP_COMMUNITY=public

# -----------------------------------------------------------------------------
# Database Connectivity
# -----------------------------------------------------------------------------
ORACLE_USER=smf
ORACLE_PASSWORD=smf
#ORACLE_SMF_SERVICE=192.168.127.40:1521/SMF
#ORACLE_SMF_SERVICE=usms:1521/SMF

#ORACLE_SMF_SERVICE=(DESCRIPTION_LIST=(FAILOVER=off)(LOAD_BALANCE=off)(DESCRIPTION=(CONNECT_TIMEOUT=5)(TRANSPORT_CONNECT_TIMEOUT=3)(RETRY_COUNT=3)(ADDRESS_LIST=(ADDRESS=(PROTOCOL=tcp)(HOST=usms)(PORT=1521)))(CONNECT_DATA=(SERVICE_NAME=SMF.usms.SMF))))

ORACLE_SMF_SERVICE="(DESCRIPTION_LIST=
  (FAILOVER=off)
  (LOAD_BALANCE=off)
  (DESCRIPTION=
    (CONNECT_TIMEOUT=5)
    (TRANSPORT_CONNECT_TIMEOUT=3)
    (RETRY_COUNT=3)
    (ADDRESS_LIST=
      (ADDRESS=(PROTOCOL=tcp)(HOST=usms)(PORT=1521))
    )
    (CONNECT_DATA=(SERVICE_NAME=SMF.usms.SMF))
  )
)"

# -----------------------------------------------------------------------------
# MCP Server
# -----------------------------------------------------------------------------
MCP_PORT=3100
MCP_API_KEY=generate-a-strong-random-secret-here

