# =============================================================================
# OCNCC Billing Engine Client Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Server Settings
# -----------------------------------------------------------------------------
# The port the API server will listen on
BE_PORT=3010

# The hostname or IP address the API server will bind to
BE_HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Swagger API Info Settings
# -----------------------------------------------------------------------------
# The fully qualified URL where this API is hosted (e.g. for Swagger UI to work correctly through proxies)
BE_SERVER_URL=http://localhost:3010

# Human-readable description for the server in Swagger UI
BE_SERVER_DESCRIPTION=Local development

# -----------------------------------------------------------------------------
# Client Identification
# -----------------------------------------------------------------------------
# The name of this client (sent in the BEG handshake to the billing engines)
BE_CLIENT_NAME=js-be-client

# -----------------------------------------------------------------------------
# Billing Engine Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of billing engines.
# Format: <id>:<primaryIP>:<primaryPort>:<secondaryIP>:<secondaryPort>
#
# Examples:
# One pair (ID 1, primary 10.0.0.1, secondary 10.0.0.2):
# BE_ENGINES=1:10.0.0.1:1500:10.0.0.2:1500
#
# Two pairs (ID 1 and ID 2):
# BE_ENGINES=1:10.0.0.1:1500:10.0.0.2:1500,2:10.0.0.3:1500:10.0.0.4:1500
BE_ENGINES=1:10.0.0.1:1500:10.0.0.2:1500,2:10.0.0.3:1500:10.0.0.4:1500

# -----------------------------------------------------------------------------
# Connection & Performance Defaults
# -----------------------------------------------------------------------------
# Request timeout in milliseconds
BE_MESSAGE_TIMEOUT_MS=2000

# Heartbeat interval in milliseconds (keeps the TCP connection alive)
BE_HEARTBEAT_INTERVAL_MS=3000

# Retry interval for dropped connections in milliseconds
BE_CONNECTION_RETRY_MS=5000

# Time in milliseconds before falling back to the primary after a failover
# Set to -1 to disable automatic failback
BE_PRIMARY_FAILBACK_MS=-1

# -----------------------------------------------------------------------------
# API Protection & Analytics
# -----------------------------------------------------------------------------
# Rate limit: Maximum API calls per second per IP
BE_RATE_LIMIT_PER_SECOND=100

# Statistics period in minutes (duration of aggregated buckets)
BE_STATS_PERIOD_MINUTES=5

# Statistics retention in days (how long to keep historical buckets)
BE_STATS_RETENTION_DAYS=3

# -----------------------------------------------------------------------------
# JWT Security
# -----------------------------------------------------------------------------
# Enable or disable JWT verification on /api endpoints
BE_JWT_ENABLED=true

# Secret used to sign and verify JSON Web Tokens (Change to a strong crypt-key in prod!)
BE_JWT_SECRET=YOUR_SUPER_SECRET_KEY_CHANGE_IN_PRODUCTION

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Whether to require JWT Bearer token authentication for API access
BE_JWT_ENABLED=false

# -----------------------------------------------------------------------------
# Redis Caching
# -----------------------------------------------------------------------------
# Enable Redis for cluster-wide API statistics persistence and sharing
BE_REDIS_ENABLED=false

# Redis connection URL (e.g. redis://username:password@host:port/db)
BE_REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Alerting and Monitoring
# -----------------------------------------------------------------------------
# Syslog server for fraud / anomaly detection alerts
BE_SYSLOG_ENABLED=false
BE_SYSLOG_HOST=localhost
BE_SYSLOG_PORT=514

# SNMP Agent for system traps
BE_SNMP_ENABLED=false
BE_SNMP_HOST=localhost
BE_SNMP_PORT=162
BE_SNMP_COMMUNITY=public

# -----------------------------------------------------------------------------
# Database Connectivity
# -----------------------------------------------------------------------------
ORACLE_USER=smf_oper
ORACLE_PASSWORD=smf_oper
ORACLE_SMF_SERVICE=SMF

(DESCRIPTION_LIST=
  (FAILOVER=on)
  (LOAD_BALANCE=off)
  (DESCRIPTION=
    (CONNECT_TIMEOUT=5)(TRANSPORT_CONNECT_TIMEOUT=3)(RETRY_COUNT=3)
    (ADDRESS_LIST=(ADDRESS=(PROTOCOL=tcp)(HOST=primary-db-host)(PORT=1521)))
    (CONNECT_DATA=(SERVICE_NAME=your_service_name))
  )
  (DESCRIPTION=
    (CONNECT_TIMEOUT=5)(TRANSPORT_CONNECT_TIMEOUT=3)(RETRY_COUNT=3)
    (ADDRESS_LIST=(ADDRESS=(PROTOCOL=tcp)(HOST=standby-db-host)(PORT=1521)))
    (CONNECT_DATA=(SERVICE_NAME=your_service_name))
  )
)
